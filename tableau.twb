            <dictionary>
              <bucket>&quot;Micro (&lt;$500K)&quot;</bucket>
              <bucket>&quot;Seed ($500K–$2M)&quot;</bucket>
              <bucket>&quot;Growth ($2M–$10M)&quot;</bucket>
              <bucket>&quot;Late Stage ($10M+)&quot;</bucket>
