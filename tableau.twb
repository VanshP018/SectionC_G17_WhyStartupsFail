          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Min Sector Startups' datatype='integer' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='30'>
              <calculation class='tableau' formula='30' />
              <range granularity='10' max='500' min='10' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1nriikx15vsubb12x68xt0sngl7m'>
            <column caption='Failure Rate %' datatype='real' default-format='n#,##0.00&quot;%&quot;;(#,##0.00&quot;%&quot;)' name='[Calculation_321444487995375616]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([is_closed]) / COUNT([name]) * 100' />
            </column>
            <column caption='Funding Tier' datatype='string' name='[Calculation_321444487996747777]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [funding_total_usd] &lt; 500000 THEN &quot;Micro (&lt;$500K)&quot;&#10;ELSEIF [funding_total_usd] &lt; 2000000 THEN &quot;Seed ($500K–$2M)&quot;&#10;ELSEIF [funding_total_usd] &lt; 10000000 THEN &quot;Growth ($2M–$10M)&quot;&#10;ELSE &quot;Late Stage ($10M+)&quot;&#10;END' />
            </column>
            <column caption='Sector Size OK' datatype='boolean' name='[Calculation_321444488022679563]' role='measure' type='nominal'>
              <calculation class='tableau' formula='COUNT([name]) &gt;= [Parameters].[Parameter 1]' />
            </column>
            <column caption='Total Funding USD' datatype='real' name='[funding_total_usd]' role='measure' type='quantitative' />
            <column caption='Is Closed' datatype='real' name='[is_closed]' role='measure' type='quantitative' />
            <column caption='Sector' datatype='string' name='[market]' role='dimension' type='nominal' />
            <column caption='Name' datatype='string' name='[name]' role='dimension' type='nominal' />
